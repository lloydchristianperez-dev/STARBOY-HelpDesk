# STARBOY HelpDesk - Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection String
# Get this from MongoDB Atlas (free tier works)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/starboyhelpdesk?retryWrites=true&w=majority

# JWT Secret Key
# Generate a secure random string (e.g., using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Port (default: 5000)
PORT=5000

# For Frontend Deployment (Vercel):
# Set these in Vercel Project Settings
# REACT_APP_API_URL=https://your-backend.vercel.app/api

# Optional: Admin Email Suffix (default: @starboy.com)
# ADMIN_EMAIL_SUFFIX=@starboy.com
